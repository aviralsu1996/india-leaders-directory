# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SMTP Credentials: Configure these to enable real email forwarding of Contact Us inquiries to your email.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# Supabase Keys for Admin Panel Connection (Public client-side keys prefixed with VITE_)
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""

# Optional news provider API keys (client-side fallback chain in src/news/providers).
# Google News RSS is tried first and needs no key. These are only used if it returns
# nothing. NOTE: VITE_-prefixed vars are bundled into the public client JS — do not
# put a paid/rate-limited key here if that's a concern. The scheduled server-side
# sync (supabase/functions/sync-news, see supabase/README_NEWS_CRON.md) uses its own
# non-VITE_ secrets (NEWS_API_KEY / GNEWS_API_KEY / MEDIASTACK_API_KEY set via
# `supabase secrets set`) and is the safer place to configure these.
VITE_GNEWS_API_KEY=""
VITE_NEWS_API_KEY=""
VITE_MEDIASTACK_API_KEY=""

